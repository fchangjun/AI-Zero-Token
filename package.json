{
  "name": "ai-zero-token",
  "version": "2.0.4",
  "description": "Local-first OpenAI-compatible AI CLI and gateway with Codex OAuth, multi-account management, and gpt-image-2 image generation/editing.",
  "license": "MIT",
  "author": "AI Zero Token Contributors",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fchangjun/AI-Zero-Token.git"
  },
  "homepage": "https://github.com/fchangjun/AI-Zero-Token#readme",
  "bugs": {
    "url": "https://github.com/fchangjun/AI-Zero-Token/issues"
  },
  "bin": {
    "azt": "dist/cli.js",
    "ai-zero-token": "dist/cli.js"
  },
  "main": "dist/desktop/main.js",
  "keywords": [
    "ai",
    "cli",
    "gateway",
    "oauth",
    "openai",
    "codex",
    "openai-compatible",
    "chatgpt",
    "gpt-image-2",
    "image-generation",
    "images-generations",
    "local-gateway",
    "multi-account"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "login": "bun src/cli.ts login",
    "status": "bun src/cli.ts status",
    "ask": "bun src/cli.ts ask",
    "start": "bun src/cli.ts start",
    "serve": "bun src/cli.ts serve",
    "dev": "node scripts/dev.mjs web",
    "build": "npm run build:ui && npm run build:server",
    "build:server": "tsup",
    "build:ui": "vite build --config admin-ui/vite.config.ts",
    "desktop": "npm run build && electron .",
    "desktop:dev": "node scripts/dev.mjs desktop",
    "dist": "npm run build && electron-builder",
    "dist:dir": "npm run build && electron-builder --dir",
    "dist:mac": "npm run dist:mac:arm64 && npm run dist:mac:x64",
    "dist:mac:arm64": "npm run build && electron-builder --mac --arm64",
    "dist:mac:x64": "npm run build && electron-builder --mac --x64",
    "dist:win": "npm run build && electron-builder --win",
    "typecheck": "npm run typecheck:server && npm run typecheck:ui",
    "typecheck:server": "bunx tsc -p tsconfig.json --noEmit",
    "typecheck:ui": "tsc -p admin-ui/tsconfig.json --noEmit",
    "prepack": "npm run build",
    "pack:dry": "npm pack --dry-run"
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "fastify": "^5.8.2",
    "fflate": "^0.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "lucide-react": "^1.14.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.10"
  },
  "build": {
    "appId": "com.aizerotoken.desktop",
    "productName": "AI Zero Token",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "admin-ui/dist/**/*",
      "build/icon.*",
      "build/tray-icon-template.png",
      "package.json",
      "README.md",
      "README.zh-CN.md",
      "LICENSE"
    ],
    "extraResources": [
      {
        "from": "build/mac-install-guide.txt",
        "to": "mac-install-guide.txt"
      }
    ],
    "extraMetadata": {
      "main": "dist/desktop/main.js"
    },
    "asar": true,
    "mac": {
      "icon": "build/icon.icns",
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 160,
          "type": "file"
        },
        {
          "x": 410,
          "y": 160,
          "type": "link",
          "path": "/Applications"
        },
        {
          "x": 270,
          "y": 300,
          "type": "file",
          "path": "build/mac-install-guide.txt"
        }
      ]
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis",
        "zip"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "files": [
    "dist",
    "admin-ui/dist",
    "build/icon.svg",
    "build/icon.png",
    "build/icon.icns",
    "build/icon.ico",
    "build/tray-icon-template.png",
    "build/mac-install-guide.txt",
    "CHANGELOG.md",
    "docs/API_USAGE.md",
    "docs/DESKTOP_RELEASE.md",
    "docs/PRODUCT_UPDATE_DESKTOP_TOOLBOX.md",
    "README.md",
    "README.zh-CN.md",
    "package.json"
  ]
}
